(function (global) {
    function capture(error, context) {
        const err = error instanceof Error ? error : new Error(String(error || 'Unknown error'));
        const data = {
            message: err.message,
            stack: err.stack || '',
            context: context || {},
            ts: new Date().toISOString()
        };

        if (global.DunamisLogger && typeof global.DunamisLogger.error === 'function') {
            global.DunamisLogger.error('tracked-error', data);
        } else {
            console.error('[tracked-error]', data);
        }

        if (global.DunamisMetrics && typeof global.DunamisMetrics.push === 'function') {
            global.DunamisMetrics.push('error', data);
        }

        return data;
    }

    global.DunamisErrorTracker = { capture };
})(typeof window !== 'undefined' ? window : globalThis);
