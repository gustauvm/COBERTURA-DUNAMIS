(function (global) {
    function log(level, message, payload) {
        const stamp = new Date().toISOString();
        const text = '[' + stamp + '] [' + String(level || 'info').toUpperCase() + '] ' + String(message || '');
        if (payload !== undefined) {
            if (level === 'error') {
                console.error(text, payload);
            } else if (level === 'warn') {
                console.warn(text, payload);
            } else {
                console.log(text, payload);
            }
            return;
        }
        if (level === 'error') {
            console.error(text);
        } else if (level === 'warn') {
            console.warn(text);
        } else {
            console.log(text);
        }
    }

    const logger = {
        log,
        error: (message, payload) => log('error', message, payload),
        warn: (message, payload) => log('warn', message, payload),
        info: (message, payload) => log('info', message, payload),
        debug: (message, payload) => log('debug', message, payload)
    };

    global.DunamisLogger = logger;
})(typeof window !== 'undefined' ? window : globalThis);
