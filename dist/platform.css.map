:root{
color-scheme:dark;
--bg:#0a0f1a;--bg-card:#111827;--bg-surface:#1a2332;--bg-hover:#1e293b;
--bg-active:#253247;--bg-input:#0d1420;
--border:#1e293b;--border-strong:#334155;--border-focus:#3b82f6;
--text:#f1f5f9;--text-secondary:#94a3b8;--text-muted:#64748b;
--blue:#3b82f6;--blue-soft:rgba(59,130,246,.15);
--green:#22c55e;--green-soft:rgba(34,197,94,.12);
--amber:#f59e0b;--amber-soft:rgba(245,158,11,.12);
--red:#ef4444;--red-soft:rgba(239,68,68,.12);
--purple:#8b5cf6;--purple-soft:rgba(139,92,246,.12);
--cyan:#06b6d4;--cyan-soft:rgba(6,182,212,.12);
--font-sans:'IBM Plex Sans',system-ui,-apple-system,sans-serif;
--font-display:'Space Grotesk','IBM Plex Sans',sans-serif;
--radius:8px;--radius-lg:12px;--radius-xl:16px;
--shadow:0 1px 3px rgba(0,0,0,.3),0 1px 2px rgba(0,0,0,.2);
--shadow-lg:0 10px 15px -3px rgba(0,0,0,.4),0 4px 6px -4px rgba(0,0,0,.3);
--shadow-xl:0 20px 25px -5px rgba(0,0,0,.5),0 8px 10px -6px rgba(0,0,0,.4);
--transition:150ms cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0}
html{font-size:14px;-webkit-font-smoothing:antialiased}
body{font-family:var(--font-sans);background:var(--bg);color:var(--text);min-height:100vh;line-height:1.5}
button,input,select,textarea{font:inherit;color:inherit}
button{border:0;cursor:pointer;background:transparent}
a{color:var(--blue);text-decoration:none}
a:hover{text-decoration:underline}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:3px}
#platform-root{min-height:100vh}
#platform-toast-region{position:fixed;bottom:16px;right:16px;z-index:9999;display:flex;flex-direction:column-reverse;gap:8px}
.platform-toast{padding:10px 16px;border-radius:var(--radius);font-size:.875rem;background:var(--bg-card);border:1px solid var(--border);box-shadow:var(--shadow-lg);max-width:380px;animation:slideIn .2s ease}
.platform-toast.success{border-left:3px solid var(--green)}
.platform-toast.error{border-left:3px solid var(--red)}
.platform-toast.info{border-left:3px solid var(--blue)}
@keyframes slideIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* === LOGIN === */
.login-shell{display:grid;grid-template-columns:1fr 420px;min-height:100vh}
.login-hero{padding:48px;display:flex;flex-direction:column;justify-content:center;gap:32px;background:linear-gradient(135deg,#0f172a 0%,#1e1b4b 50%,#0f172a 100%);border-right:1px solid var(--border)}
.login-brand{display:flex;flex-direction:column;gap:16px}
.brand-mark{display:flex;align-items:center;gap:12px}
.brand-logo{width:40px;height:40px;border-radius:10px;object-fit:contain}
.brand-mark strong{font-size:.875rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text)}
.brand-mark span{color:var(--text-muted);font-size:.75rem;display:block}
.login-headline{font-family:var(--font-display);font-size:clamp(2rem,4vw,3.5rem);line-height:1.1;font-weight:700;background:linear-gradient(135deg,#f1f5f9,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.login-copy{color:var(--text-secondary);max-width:480px;font-size:.9rem}
.hero-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:24px}
.hero-card{padding:16px;border-radius:var(--radius-lg);background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06)}
.hero-card span{font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:var(--blue)}
.hero-card h3{font-size:.95rem;margin:6px 0 4px}
.hero-card p{color:var(--text-muted);font-size:.8rem;margin:0}
.login-panel-wrap{display:flex;align-items:center;justify-content:center;padding:32px;background:var(--bg)}
.login-form-panel{width:100%;max-width:360px;display:flex;flex-direction:column;gap:20px}
.login-form-panel h2{font-family:var(--font-display);font-size:1.5rem}
.login-form-panel form{display:flex;flex-direction:column;gap:12px}
.eyebrow{font-size:.65rem;text-transform:uppercase;letter-spacing:.12em;color:var(--blue);font-weight:600}
.helper{color:var(--text-muted);font-size:.8rem}
.muted{color:var(--text-muted);font-size:.75rem}

/* === FORM CONTROLS === */
.field{display:flex;flex-direction:column;gap:4px}
.field label{font-size:.75rem;color:var(--text-secondary);font-weight:500;text-transform:uppercase;letter-spacing:.06em}
.field input,.field select,.field textarea,
.search-box input,.form-input{
width:100%;height:36px;padding:0 10px;border-radius:var(--radius);
border:1px solid var(--border);background:var(--bg-input);color:var(--text);
font-size:.875rem;transition:border-color var(--transition)}
.field textarea,.form-textarea{height:auto;min-height:72px;padding:8px 10px;resize:vertical}
.field input:focus,.field select:focus,.field textarea:focus,.form-input:focus,.form-textarea:focus,.search-box input:focus{
border-color:var(--border-focus);outline:none;box-shadow:0 0 0 2px rgba(59,130,246,.15)}

.btn-primary{height:36px;padding:0 14px;border-radius:var(--radius);background:var(--blue);color:#fff;font-weight:600;font-size:.8rem;transition:all var(--transition)}
.btn-primary:hover{background:#2563eb;box-shadow:0 0 0 2px rgba(59,130,246,.25)}
.btn-secondary{height:32px;padding:0 12px;border-radius:var(--radius);background:var(--bg-surface);color:var(--text);border:1px solid var(--border);font-size:.8rem;transition:all var(--transition)}
.btn-secondary:hover{background:var(--bg-hover);border-color:var(--border-strong)}
.btn-ghost{height:32px;padding:0 10px;border-radius:var(--radius);color:var(--text-secondary);font-size:.8rem;transition:color var(--transition)}
.btn-ghost:hover{color:var(--text);background:var(--bg-hover)}
.btn-danger{height:32px;padding:0 12px;border-radius:var(--radius);background:var(--red-soft);color:var(--red);border:1px solid rgba(239,68,68,.2);font-size:.8rem}
.btn-danger:hover{background:rgba(239,68,68,.2)}
.button-row{display:flex;gap:8px;align-items:center}

/* === SHELL LAYOUT === */
.platform-shell{display:grid;grid-template-columns:240px 1fr;min-height:100vh}
.sidebar{position:sticky;top:0;height:100vh;overflow-y:auto;background:var(--bg);border-right:1px solid var(--border);display:flex;flex-direction:column;padding:0}
.sidebar-header{padding:16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.sidebar-header img{width:28px;height:28px;border-radius:6px}
.sidebar-header h1{font-size:.875rem;font-weight:700;font-family:var(--font-display);letter-spacing:.02em}
.sidebar-header span{font-size:.65rem;color:var(--text-muted);display:block}

.domain-nav{flex:1;padding:8px;display:flex;flex-direction:column;gap:2px}
.domain-nav button{display:flex;align-items:center;gap:10px;width:100%;text-align:left;padding:8px 12px;border-radius:var(--radius);color:var(--text-secondary);font-size:.8rem;font-weight:500;transition:all var(--transition);min-height:36px}
.domain-nav button:hover{background:var(--bg-hover);color:var(--text)}
.domain-nav button.active{background:var(--blue-soft);color:var(--blue);font-weight:600}
.domain-nav button .nav-icon{width:18px;text-align:center;font-size:.9rem;flex-shrink:0}
.domain-nav button .nav-label{flex:1}
.domain-nav button .nav-badge{font-size:.65rem;padding:1px 6px;border-radius:99px;background:var(--red-soft);color:var(--red)}
.nav-section{padding:8px 12px 4px;font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);font-weight:600}

.sidebar-footer{padding:12px 16px;border-top:1px solid var(--border);font-size:.7rem;color:var(--text-muted);line-height:1.4}
.sidebar-user{padding:12px 16px;border-top:1px solid var(--border);display:flex;align-items:center;gap:10px}
.sidebar-user .user-avatar{width:28px;height:28px;border-radius:50%;background:var(--purple-soft);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:var(--purple);flex-shrink:0}
.sidebar-user .user-info{flex:1;min-width:0}
.sidebar-user .user-name{font-size:.8rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sidebar-user .user-role{font-size:.65rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em}

.shell-main{display:flex;flex-direction:column;min-height:100vh;background:var(--bg)}

/* === TOPBAR === */
.topbar{height:48px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;padding:0 16px;background:var(--bg);position:sticky;top:0;z-index:30}
.topbar-breadcrumb{font-size:.8rem;color:var(--text-secondary);display:flex;align-items:center;gap:6px}
.topbar-breadcrumb strong{color:var(--text);font-weight:600}
.search-box{flex:1;max-width:480px;display:flex;align-items:center;gap:8px;height:32px;padding:0 10px;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg-input);transition:border-color var(--transition)}
.search-box:focus-within{border-color:var(--border-focus)}
.search-box span{color:var(--text-muted);font-size:.75rem;flex-shrink:0}
.search-box input{border:0;background:transparent;height:100%;padding:0;font-size:.8rem;flex:1;min-width:0}
.search-box input:focus{box-shadow:none}
.search-box kbd{font-size:.6rem;padding:2px 5px;border-radius:4px;border:1px solid var(--border-strong);color:var(--text-muted);font-family:inherit;margin-left:auto;flex-shrink:0}
.topbar-actions{display:flex;align-items:center;gap:6px;margin-left:auto}
.topbar-actions select{height:32px;padding:0 8px;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg-input);font-size:.75rem;color:var(--text-secondary)}

/* === CONTENT === */
.content-wrap{flex:1;padding:20px;overflow-y:auto}
.content-grid{display:grid;grid-template-columns:1fr 320px;gap:20px}
.main-column{display:flex;flex-direction:column;gap:16px;min-width:0}
.aside-column{display:flex;flex-direction:column;gap:12px}
.page-header{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:4px}
.page-header-text h2{font-family:var(--font-display);font-size:1.25rem;font-weight:700}
.page-header-text p{color:var(--text-muted);font-size:.8rem;margin-top:2px}
.section-title{font-family:var(--font-display);font-size:1rem;font-weight:700;margin-bottom:8px}
.toolbar-actions{display:flex;gap:6px;align-items:center;flex-wrap:wrap}

/* === METRIC CARDS === */
.metrics-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.metric-card{padding:14px 16px;border-radius:var(--radius-lg);background:var(--bg-card);border:1px solid var(--border)}
.metric-card .metric-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);font-weight:600}
.metric-card .metric-value{font-family:var(--font-display);font-size:1.75rem;font-weight:700;margin:4px 0 2px}
.metric-card .metric-meta{font-size:.7rem;color:var(--text-muted);display:flex;align-items:center;gap:4px}
.metric-card .metric-delta{font-weight:600}
.metric-card .metric-delta.up{color:var(--green)}
.metric-card .metric-delta.down{color:var(--red)}
.metric-card .metric-delta.flat{color:var(--amber)}
.metric-card.accent-blue{border-left:3px solid var(--blue)}
.metric-card.accent-green{border-left:3px solid var(--green)}
.metric-card.accent-amber{border-left:3px solid var(--amber)}
.metric-card.accent-red{border-left:3px solid var(--red)}
.metric-card.accent-purple{border-left:3px solid var(--purple)}
.metric-card.accent-cyan{border-left:3px solid var(--cyan)}

/* === PANELS/CARDS === */
.panel{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
.panel-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border)}
.panel-header h3{font-size:.875rem;font-weight:600}
.panel-body{padding:0}
.panel-footer{padding:10px 16px;border-top:1px solid var(--border);font-size:.75rem;color:var(--text-muted)}
.panel-empty{padding:32px 16px;text-align:center;color:var(--text-muted)}
.panel-empty strong{display:block;color:var(--text-secondary);margin-bottom:4px}

/* === DATA TABLE === */
.data-table{width:100%;border-collapse:collapse;font-size:.8rem}
.data-table thead th{position:sticky;top:0;background:var(--bg-surface);padding:8px 12px;text-align:left;font-weight:600;font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);border-bottom:1px solid var(--border);white-space:nowrap}
.data-table tbody tr{border-bottom:1px solid var(--border);transition:background var(--transition);cursor:pointer}
.data-table tbody tr:hover{background:var(--bg-hover)}
.data-table td{padding:8px 12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px}
.data-table .cell-name{font-weight:600;color:var(--text)}
.data-table .cell-sub{color:var(--text-muted);font-size:.75rem}

/* === STATUS / BADGE === */
.badge{display:inline-flex;align-items:center;height:22px;padding:0 8px;border-radius:99px;font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:.04em;gap:4px}
.badge-ok,.badge-plantao{background:var(--green-soft);color:var(--green)}
.badge-warn,.badge-ft,.badge-medium,.badge-attention{background:var(--amber-soft);color:var(--amber)}
.badge-bad,.badge-afastado,.badge-high,.badge-critical{background:var(--red-soft);color:var(--red)}
.badge-folga{background:var(--purple-soft);color:var(--purple)}
.badge-blue,.badge-info{background:var(--blue-soft);color:var(--blue)}
.badge-low,.badge-stable{background:var(--green-soft);color:var(--green)}
.badge-neutral{background:rgba(148,163,184,.1);color:var(--text-secondary)}
.badge::before{content:"";width:5px;height:5px;border-radius:50%;background:currentColor}

/* === SEGMENTED CONTROLS === */
.segmented{display:inline-flex;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg-input);overflow:hidden}
.segmented button{padding:0 12px;height:30px;font-size:.75rem;font-weight:500;color:var(--text-secondary);border-right:1px solid var(--border);transition:all var(--transition)}
.segmented button:last-child{border-right:0}
.segmented button:hover{color:var(--text);background:var(--bg-hover)}
.segmented button.active{background:var(--blue-soft);color:var(--blue);font-weight:600}

/* === QUEUE/KANBAN === */
.queue-grid{display:grid;gap:8px}
.queue-item{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg-card);transition:background var(--transition)}
.queue-item:hover{background:var(--bg-hover)}
.queue-item .qi-icon{width:32px;height:32px;border-radius:var(--radius);display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
.queue-item .qi-icon.qi-reassign{background:var(--blue-soft);color:var(--blue)}
.queue-item .qi-icon.qi-campaign{background:var(--purple-soft);color:var(--purple)}
.queue-item .qi-icon.qi-issue{background:var(--red-soft);color:var(--red)}
.queue-item .qi-icon.qi-vehicle{background:var(--cyan-soft);color:var(--cyan)}
.queue-item .qi-icon.qi-execution{background:var(--green-soft);color:var(--green)}
.queue-item .qi-body{flex:1;min-width:0}
.queue-item .qi-title{font-weight:600;font-size:.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.queue-item .qi-meta{font-size:.7rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.queue-item .qi-actions{display:flex;gap:4px;align-items:center;flex-shrink:0}

/* === FORCE MAP === */
.force-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px}
.force-card{padding:14px;border-radius:var(--radius-lg);background:var(--bg-card);border:1px solid var(--border);transition:all var(--transition);cursor:pointer;position:relative;overflow:hidden}
.force-card::before{content:"";position:absolute;top:0;left:0;right:0;height:3px}
.force-card.risk-low::before{background:var(--green)}
.force-card.risk-medium::before{background:var(--amber)}
.force-card.risk-high::before{background:var(--red)}
.force-card:hover{border-color:var(--border-strong);transform:translateY(-1px);box-shadow:var(--shadow-lg)}
.force-card .fc-header{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px}
.force-card .fc-name{font-weight:700;font-size:.85rem}
.force-card .fc-client{font-size:.7rem;color:var(--text-muted)}
.force-card .fc-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.force-card .fc-stat{text-align:center;padding:6px 4px;border-radius:var(--radius);background:rgba(255,255,255,.03)}
.force-card .fc-stat small{display:block;font-size:.6rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.04em}
.force-card .fc-stat strong{font-size:1rem;font-family:var(--font-display)}
.force-card .fc-stat.gap-positive strong{color:var(--red)}
.force-card .fc-stat.gap-negative strong{color:var(--green)}

/* === SIGNAL / ACTIVITY LIST === */
.signal-list{display:flex;flex-direction:column}
.signal-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-bottom:1px solid var(--border);transition:background var(--transition)}
.signal-item:last-child{border-bottom:0}
.signal-item:hover{background:var(--bg-hover)}
.signal-item .si-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.signal-item .si-dot.urgent{background:var(--red)}
.signal-item .si-dot.normal{background:var(--amber)}
.signal-item .si-dot.ok{background:var(--green)}
.signal-item .si-body{flex:1;min-width:0}
.signal-item .si-title{font-size:.8rem;font-weight:500}
.signal-item .si-meta{font-size:.7rem;color:var(--text-muted)}
.signal-item .si-time{font-size:.65rem;color:var(--text-muted);white-space:nowrap;flex-shrink:0}

/* === CHARTS (CSS-only) === */
.bar-chart{display:flex;flex-direction:column;gap:6px}
.bar-row{display:grid;grid-template-columns:120px 1fr 60px;gap:10px;align-items:center;font-size:.8rem}
.bar-row .bar-label{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500}
.bar-row .bar-track{height:8px;border-radius:99px;background:rgba(255,255,255,.06);overflow:hidden}
.bar-row .bar-fill{height:100%;border-radius:99px;background:linear-gradient(90deg,var(--blue),var(--cyan));transition:width .6s ease}
.bar-row .bar-value{text-align:right;font-weight:600;font-family:var(--font-display);font-size:.85rem}
.bar-row.bar-warn .bar-fill{background:linear-gradient(90deg,var(--amber),#fbbf24)}
.bar-row.bar-bad .bar-fill{background:linear-gradient(90deg,var(--red),#f87171)}

.mini-chart{display:flex;align-items:flex-end;gap:2px;height:32px}
.mini-chart .mc-bar{flex:1;border-radius:2px 2px 0 0;background:var(--blue);min-width:3px;transition:height .3s ease}

/* === DRAWER (Entity Detail) === */
.drawer-overlay{position:fixed;inset:0;z-index:50;display:flex;justify-content:flex-end}
.drawer-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(2px)}
.drawer-panel{position:relative;width:560px;max-width:100vw;height:100%;background:var(--bg);border-left:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column;animation:drawerIn .2s ease}
@keyframes drawerIn{from{transform:translateX(24px);opacity:.8}to{transform:none;opacity:1}}
.drawer-top{padding:16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
.drawer-top h2{font-family:var(--font-display);font-size:1.1rem;font-weight:700}
.drawer-top .drawer-type{font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;color:var(--blue);font-weight:600;margin-bottom:2px}
.drawer-top .drawer-subtitle{font-size:.8rem;color:var(--text-muted);margin-top:2px}
.drawer-top-actions{display:flex;gap:4px;flex-shrink:0}
.drawer-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border-bottom:1px solid var(--border)}
.drawer-stats .ds-item{padding:10px 14px;background:var(--bg);text-align:center}
.drawer-stats .ds-item small{display:block;font-size:.6rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted)}
.drawer-stats .ds-item strong{font-size:1.1rem;font-family:var(--font-display)}
.drawer-body{flex:1;padding:16px;display:flex;flex-direction:column;gap:12px}
.drawer-section{border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
.drawer-section-header{padding:10px 14px;background:var(--bg-surface);border-bottom:1px solid var(--border);font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text-secondary);display:flex;justify-content:space-between;align-items:center}
.drawer-section-body{padding:12px 14px}
.drawer-field-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px}
.drawer-field{display:flex;flex-direction:column;gap:2px}
.drawer-field.full{grid-column:1/-1}
.drawer-field label{font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted);font-weight:500}
.drawer-field .fv{font-size:.85rem;word-break:break-word}
.drawer-field input,.drawer-field select,.drawer-field textarea{width:100%;height:32px;padding:0 8px;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg-input);font-size:.8rem}
.drawer-field textarea{height:auto;min-height:56px;padding:6px 8px;resize:vertical}
.drawer-actions{display:flex;gap:6px;padding:12px 16px;border-top:1px solid var(--border);background:var(--bg)}
.drawer-timeline{display:flex;flex-direction:column}
.drawer-timeline-item{padding:8px 0;border-bottom:1px solid var(--border);display:flex;gap:8px;align-items:flex-start}
.drawer-timeline-item:last-child{border-bottom:0}
.drawer-timeline-item .tl-dot{width:8px;height:8px;border-radius:50%;background:var(--border-strong);margin-top:5px;flex-shrink:0}
.drawer-timeline-item .tl-text{font-size:.8rem}
.drawer-timeline-item .tl-time{font-size:.65rem;color:var(--text-muted)}

/* === COMMAND PALETTE === */
.command-overlay{position:fixed;inset:0;z-index:60;display:flex;justify-content:center;padding-top:80px}
.command-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(3px)}
.command-box{position:relative;width:560px;max-width:calc(100vw - 32px);max-height:420px;background:var(--bg-card);border:1px solid var(--border-strong);border-radius:var(--radius-xl);box-shadow:var(--shadow-xl);display:flex;flex-direction:column;overflow:hidden;animation:cmdIn .15s ease}
@keyframes cmdIn{from{opacity:0;transform:translateY(-8px) scale(.98)}to{opacity:1;transform:none}}
.command-input{display:flex;align-items:center;gap:10px;padding:12px 16px;border-bottom:1px solid var(--border)}
.command-input input{flex:1;border:0;background:transparent;font-size:.9rem;outline:none}
.command-input .cmd-icon{color:var(--text-muted);font-size:.8rem;flex-shrink:0}
.command-results{flex:1;overflow-y:auto;padding:6px}
.command-item{display:flex;align-items:center;gap:10px;width:100%;padding:8px 12px;border-radius:var(--radius);text-align:left;color:var(--text-secondary);font-size:.8rem;transition:all var(--transition)}
.command-item:hover,.command-item.active{background:var(--bg-hover);color:var(--text)}
.command-item strong{display:block;font-weight:600;color:var(--text);font-size:.85rem}
.command-item small{color:var(--text-muted)}
.command-item .ci-icon{width:24px;text-align:center;font-size:.9rem;flex-shrink:0}

/* === COMPOSE MODAL === */
.modal-overlay{position:fixed;inset:0;z-index:55;display:flex;align-items:center;justify-content:center;padding:20px}
.modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.6)}
.modal-box{position:relative;width:640px;max-width:100%;max-height:90vh;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-xl);display:flex;flex-direction:column;overflow:hidden;box-shadow:var(--shadow-xl);animation:cmdIn .15s ease}
.modal-header{padding:16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.modal-header h3{font-size:1rem;font-weight:600;font-family:var(--font-display)}
.modal-body{flex:1;overflow-y:auto;padding:16px}
.modal-body .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.modal-body .form-grid .full{grid-column:1/-1}
.modal-footer{padding:12px 16px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px}

/* === COMPLIANCE HEATMAP === */
.compliance-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px}
.compliance-item{padding:10px 12px;border-radius:var(--radius);border:1px solid var(--border);background:var(--bg-card);display:flex;align-items:center;gap:10px}
.compliance-item .ci-level{width:4px;height:32px;border-radius:2px;flex-shrink:0}
.compliance-item .ci-level.risk-low{background:var(--green)}
.compliance-item .ci-level.risk-medium{background:var(--amber)}
.compliance-item .ci-level.risk-high{background:var(--red)}
.compliance-item .ci-body{flex:1;min-width:0}
.compliance-item .ci-name{font-size:.8rem;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.compliance-item .ci-detail{font-size:.7rem;color:var(--text-muted)}

/* === ANALYTICS/BI === */
.kpi-strip{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px}
.kpi-card{padding:12px;border-radius:var(--radius);background:var(--bg-card);border:1px solid var(--border);text-align:center}
.kpi-card .kpi-number{font-family:var(--font-display);font-size:1.5rem;font-weight:700}
.kpi-card .kpi-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-top:2px}

.donut-chart{width:80px;height:80px;border-radius:50%;background:conic-gradient(var(--green) var(--pct,70%),rgba(255,255,255,.06) 0);display:flex;align-items:center;justify-content:center;margin:0 auto}
.donut-chart .donut-inner{width:56px;height:56px;border-radius:50%;background:var(--bg-card);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:1rem;font-weight:700}

/* === ASIDE WIDGETS === */
.aside-card{border:1px solid var(--border);border-radius:var(--radius-lg);background:var(--bg-card);overflow:hidden}
.aside-card-header{padding:10px 14px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.aside-card-header h4{font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text-secondary)}
.aside-card-body{padding:0}
.aside-item{display:flex;align-items:center;gap:8px;padding:8px 14px;border-bottom:1px solid var(--border);transition:background var(--transition)}
.aside-item:last-child{border-bottom:0}
.aside-item:hover{background:var(--bg-hover)}

/* === PUBLIC PAGE === */
.public-page{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;background:linear-gradient(135deg,var(--bg) 0%,#1e1b4b 100%)}
.public-card{width:560px;max-width:100%;padding:24px;border-radius:var(--radius-xl);background:var(--bg-card);border:1px solid var(--border);box-shadow:var(--shadow-xl)}
.public-card h1,.public-card h2{font-family:var(--font-display);margin:0 0 4px}
.public-card .public-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border-radius:var(--radius);overflow:hidden;margin:12px 0}
.public-card .ps-item{padding:10px;background:var(--bg);text-align:center}
.public-card .ps-item small{display:block;font-size:.6rem;text-transform:uppercase;color:var(--text-muted);letter-spacing:.06em}
.public-card .ps-item strong{font-size:1rem;font-family:var(--font-display)}

/* === LOADING/EMPTY/ERROR === */
.loading-state{display:flex;align-items:center;justify-content:center;padding:48px 20px;flex-direction:column;gap:8px}
.loading-spinner{width:24px;height:24px;border:3px solid var(--border);border-top-color:var(--blue);border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.empty-state{padding:32px 16px;text-align:center}
.empty-state .empty-icon{font-size:1.5rem;margin-bottom:8px}
.empty-state strong{display:block;font-size:.85rem;color:var(--text-secondary)}
.empty-state p{color:var(--text-muted);font-size:.75rem;margin-top:4px}
.error-state{padding:32px 16px;text-align:center;color:var(--red)}

/* === MOBILE + RESPONSIVE === */
.mobile-domain-bar{display:none;overflow-x:auto;border-bottom:1px solid var(--border);background:var(--bg);padding:0 8px;white-space:nowrap}
.mobile-domain-bar button{padding:8px 12px;font-size:.7rem;font-weight:500;color:var(--text-secondary);border-bottom:2px solid transparent;flex-shrink:0}
.mobile-domain-bar button.active{color:var(--blue);border-bottom-color:var(--blue)}

@media(max-width:1024px){
.platform-shell{grid-template-columns:1fr}
.sidebar{display:none}
.mobile-domain-bar{display:flex}
.content-grid{grid-template-columns:1fr}
.aside-column{display:none}
.metrics-row{grid-template-columns:repeat(2,1fr)}
.force-grid{grid-template-columns:1fr}
.entity-row{grid-template-columns:1fr}
.drawer-panel{width:100%}
.login-shell{grid-template-columns:1fr}
.login-hero{display:none}
.hero-grid{grid-template-columns:1fr}
}

@media(max-width:640px){
.metrics-row{grid-template-columns:1fr}
.topbar{flex-wrap:wrap;height:auto;padding:8px 12px;gap:8px}
.search-box{max-width:100%;flex:1 1 100%}
.topbar-actions{flex:1 1 100%;justify-content:flex-end}
.modal-body .form-grid{grid-template-columns:1fr}
.drawer-stats{grid-template-columns:repeat(2,1fr)}
.drawer-field-grid{grid-template-columns:1fr}
.bar-row{grid-template-columns:80px 1fr 40px}
}

/* === MISSING CLASSES PATCH === */
.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.fc-bar{height:4px;background:var(--bg);border-radius:2px;margin-top:8px;overflow:hidden}
.fc-bar-fill{height:100%;border-radius:2px;background:var(--green);transition:width .3s ease}
.risk-high .fc-bar-fill{background:var(--red)}
.risk-medium .fc-bar-fill{background:var(--amber)}
.qi-badges{display:flex;gap:4px;align-items:center;flex-shrink:0}
.compliance-list{display:flex;flex-direction:column}
.kpi-val{font-family:var(--font-display);font-size:1.5rem;font-weight:700}
.kpi-lbl{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);margin-top:2px}
.loading-shell{min-height:100vh;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:12px;background:var(--bg)}
.content-area{padding:24px;overflow-y:auto;flex:1}
.sidebar-open{transform:translateX(0) !important}
.mobile-menu-btn{display:none}
.topbar-left{display:flex;align-items:center;gap:12px}
.topbar-right{display:flex;align-items:center;gap:6px}
.topbar-title{font-size:1rem;font-weight:600;font-family:var(--font-display);margin:0}
.domain-btn{display:flex;align-items:center;gap:10px;width:100%;padding:8px 14px;border-radius:var(--radius);color:var(--text-secondary);transition:all var(--transition);font-size:.85rem;text-align:left}
.domain-btn:hover{background:var(--bg-hover);color:var(--text)}
.domain-btn.active{background:var(--blue-soft);color:var(--blue);font-weight:600}
.domain-icon{font-size:1.1rem;width:22px;text-align:center;flex-shrink:0}
.domain-label{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.sidebar-logo{width:32px;height:32px;border-radius:8px;object-fit:contain}
.drawer-header{display:flex;justify-content:space-between;align-items:flex-start;padding:20px 24px;border-bottom:1px solid var(--border)}
.drawer-header h2{font-family:var(--font-display);font-size:1.1rem;margin:0}
.drawer-header small{color:var(--text-muted);font-size:.75rem}
.drawer-tabs{display:flex;border-bottom:1px solid var(--border);padding:0 24px}
.drawer-tab{padding:8px 16px;font-size:.8rem;color:var(--text-muted);border-bottom:2px solid transparent;transition:all var(--transition)}
.drawer-tab:hover{color:var(--text)}
.drawer-tab.active{color:var(--blue);border-bottom-color:var(--blue)}
.drawer-body{padding:20px 24px;overflow-y:auto;flex:1}
.status-actions{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.cmd-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:var(--radius);cursor:pointer;transition:background var(--transition)}
.cmd-item:hover{background:var(--bg-hover)}
.cmd-icon{width:24px;text-align:center;font-size:1rem}
.cmd-text{flex:1;min-width:0}
.cmd-text strong{display:block;font-size:.85rem}
.cmd-text small{color:var(--text-muted);font-size:.7rem}
.command-input{width:100%;padding:12px 16px;border:0;border-bottom:1px solid var(--border);background:transparent;font-size:1rem;outline:none}
.command-list{max-height:320px;overflow-y:auto;padding:8px}
.command-footer{padding:8px 16px;border-top:1px solid var(--border);font-size:.7rem;color:var(--text-muted);display:flex;gap:12px}
.command-footer kbd{background:var(--bg);padding:1px 5px;border-radius:3px;font-size:.65rem;border:1px solid var(--border)}
.btn-icon{width:32px;height:32px;display:inline-flex;align-items:center;justify-content:center;border-radius:var(--radius);transition:background var(--transition);font-size:1rem}
.btn-icon:hover{background:var(--bg-hover)}
.mc-sub{font-size:.65rem;color:var(--text-muted);margin-top:2px}
.df{display:flex;flex-direction:column;gap:2px}
.df-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text-muted)}
.df-value{font-size:.85rem}
.drawer-field-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.table-wrap{overflow-x:auto}
.data-table.compact th,.data-table.compact td{padding:6px 10px;font-size:.75rem}
.search-input{padding:7px 12px;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg-input);font-size:.85rem;min-width:200px;outline:none;transition:border-color var(--transition)}
.search-input:focus{border-color:var(--border-focus)}
.chip{padding:4px 10px;border-radius:99px;font-size:.75rem;border:1px solid var(--border);background:transparent;color:var(--text-secondary);transition:all var(--transition)}
.chip:hover{background:var(--bg-hover);color:var(--text)}
.chip-active{background:var(--blue-soft);border-color:var(--blue);color:var(--blue)}
.toolbar{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.pagination{display:flex;align-items:center;justify-content:center;gap:12px;padding:12px 0}
.page-indicator{font-size:.8rem;color:var(--text-muted)}
.modal-header{display:flex;justify-content:space-between;align-items:center;padding:16px 24px;border-bottom:1px solid var(--border)}
.modal-header h2{font-family:var(--font-display);font-size:1rem;margin:0}
.modal-footer{display:flex;justify-content:flex-end;gap:8px;padding:16px 24px;border-top:1px solid var(--border)}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;padding:20px 24px}
.form-grid .field.full{grid-column:1/-1}
.form-input{width:100%;padding:8px 12px;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg-input);font-size:.85rem;outline:none;transition:border-color var(--transition)}
.form-input:focus{border-color:var(--border-focus)}
.form-textarea{resize:vertical;min-height:60px}
.btn-secondary{padding:6px 14px;border-radius:var(--radius);font-size:.8rem;font-weight:500;background:var(--bg-surface);border:1px solid var(--border);color:var(--text);transition:all var(--transition)}
.btn-secondary:hover{background:var(--bg-hover);border-color:var(--border-strong)}
.btn-xs{padding:2px 8px;font-size:.7rem}
.sidebar-footer{margin-top:auto;padding:12px 16px;border-top:1px solid var(--border)}
.sidebar-user{display:flex;align-items:center;gap:8px;margin-bottom:8px}
.user-avatar{width:30px;height:30px;border-radius:50%;background:var(--blue-soft);color:var(--blue);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.75rem;flex-shrink:0}
.user-info strong{font-size:.8rem;display:block}
.user-info small{color:var(--text-muted);font-size:.65rem}

/* === RESPONSIVE === */
@media(max-width:1024px){
    .sidebar{position:fixed;left:0;top:0;bottom:0;z-index:100;transform:translateX(-100%);transition:transform .25s ease}
    .mobile-menu-btn{display:inline-flex}
    .two-col,.three-col{grid-template-columns:1fr}
    .metrics-row{grid-template-columns:repeat(2,1fr)}
    .hero-grid{grid-template-columns:1fr}
    .login-shell{grid-template-columns:1fr}
    .login-hero{display:none}
}
@media(max-width:640px){
    .metrics-row{grid-template-columns:1fr}
    .kpi-strip{grid-template-columns:repeat(2,1fr)}
    .force-grid{grid-template-columns:1fr}
    .drawer-panel{width:100%}
    .drawer-field-grid{grid-template-columns:1fr}
    .form-grid{grid-template-columns:1fr}
}

/* === PATCH: Missing classes for platform-rebuild.js === */
.login-card{padding:48px;border-radius:var(--radius-xl);background:var(--bg-card);border:1px solid var(--border);box-shadow:var(--shadow-xl);text-align:center;max-width:420px;width:100%}
.login-shell{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;background:linear-gradient(135deg,#0a0f1a 0%,#1e1b4b 50%,#0a0f1a 100%)}
.login-title{font-family:var(--font-display);font-size:2rem;font-weight:700;margin-bottom:8px;background:linear-gradient(135deg,#f1f5f9,#3b82f6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.login-subtitle{color:var(--text-secondary);font-size:.9rem;margin-bottom:24px}
.btn-lg{height:44px;padding:0 24px;font-size:.95rem}
.btn-sm{height:28px;padding:0 10px;font-size:.75rem}
.section-header{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-bottom:12px;margin-top:20px}
.section-header:first-child{margin-top:0}
.section-header h3{font-family:var(--font-display);font-size:1rem;font-weight:600;margin:0}
.section-header h4{font-family:var(--font-display);font-size:.9rem;font-weight:600;margin:0}
.activity-list{display:flex;flex-direction:column;gap:8px}
.queue-item{cursor:pointer}
.queue-item-header{display:flex;justify-content:space-between;align-items:center;gap:8px}
.queue-item-header strong{font-size:.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.queue-item-meta{font-size:.7rem;color:var(--text-muted);margin-top:2px}
.filter-group{display:flex;gap:4px;align-items:center;flex-wrap:wrap}
.pagination-bar{display:flex;justify-content:space-between;align-items:center;padding:12px 0;font-size:.8rem;color:var(--text-muted)}
.text-muted{color:var(--text-muted)}
.force-card-header{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px}
.force-card-body{display:flex;flex-direction:column;gap:6px}
.force-bar{height:6px;border-radius:3px;background:rgba(255,255,255,.06);overflow:hidden}
.force-bar-fill{height:100%;border-radius:3px;transition:width .4s ease}
.force-count{font-size:.75rem;color:var(--text-secondary)}
.domain-content{display:flex;flex-direction:column;gap:4px}
.domain-content h2{font-family:var(--font-display);font-size:1.25rem;font-weight:700;margin-bottom:8px}
.bar-chart-row{display:grid;grid-template-columns:140px 1fr;gap:10px;align-items:center;font-size:.8rem}
.bar-chart-row .bar-label{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500}
.bar-chart-row .bar-track{height:8px;border-radius:99px;background:rgba(255,255,255,.06);overflow:hidden}
.bar-chart-row .bar-fill{height:100%;border-radius:99px;transition:width .6s ease}
.signal-item{padding:10px 14px;border-bottom:1px solid var(--border)}
.signal-item strong{display:block;font-size:.85rem;margin-bottom:2px}
.signal-item p{font-size:.8rem;color:var(--text-secondary);margin:4px 0}
.signal-meta{font-size:.7rem;color:var(--text-muted)}
.drawer-title{display:flex;align-items:center;gap:10px;flex:1;min-width:0}
.drawer-title strong{font-size:1.1rem;font-family:var(--font-display)}
.drawer-details{display:flex;flex-direction:column;gap:10px}
.detail-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border);font-size:.85rem}
.detail-row:last-child{border-bottom:0}
.detail-label{color:var(--text-muted);font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;font-weight:500}
.drawer-status-actions{display:flex;flex-wrap:wrap;gap:6px}
.comment-form{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.comment-textarea{width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg-input);resize:vertical;min-height:48px;font-size:.85rem;outline:none}
.comment-textarea:focus{border-color:var(--border-focus)}
.form-group{display:flex;flex-direction:column;gap:4px;margin-bottom:12px}
.form-group label{font-size:.75rem;color:var(--text-secondary);font-weight:500;text-transform:uppercase;letter-spacing:.06em}
.sidebar-item{display:flex;align-items:center;gap:10px;width:100%;text-align:left;padding:8px 14px;border-radius:var(--radius);color:var(--text-secondary);font-size:.85rem;font-weight:500;transition:all var(--transition)}
.sidebar-item:hover{background:var(--bg-hover);color:var(--text)}
.sidebar-item.active{background:var(--blue-soft);color:var(--blue);font-weight:600}
.sidebar-icon{font-size:1.1rem;width:22px;text-align:center;flex-shrink:0}
.sidebar-label{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.topbar-domain{font-size:.8rem;color:var(--text-muted)}
.topbar-user{font-size:.75rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px}
.spinner{width:24px;height:24px;border:3px solid var(--border);border-top-color:var(--blue);border-radius:50%;animation:spin .6s linear infinite}
.badge-muted{background:rgba(148,163,184,.1);color:var(--text-secondary)}
.health-output{background:var(--bg-surface);padding:12px;border-radius:var(--radius);border:1px solid var(--border)}
