(function (global) {
    var clientCache = null;
    var queueProcessing = null;
    var bindingsReady = false;
    var MUTATION_QUEUE_KEY = 'dunamis-supabase-mutation-queue-v1';
    var currentProfileCache = { userId: '', profile: null };

    function createClient() {
        if (!global.supabase || !global.CONFIG?.supabase?.url || !global.CONFIG?.supabase?.anonKey) {
            throw new Error('Supabase nao configurado.');
        }
        if (global.__dunamisSupabaseClient) {
            clientCache = global.__dunamisSupabaseClient;
            return clientCache;
        }
        if (!clientCache) {
            clientCache = global.supabase.createClient(global.CONFIG.supabase.url, global.CONFIG.supabase.anonKey, {
                auth: { persistSession: true }
            });
            global.__dunamisSupabaseClient = clientCache;
        }
        return clientCache;
    }

    function getStorage() {
        try {
            return global.localStorage || null;
        } catch (_) {
            return null;
        }
    }

    function readQueue() {
        var storage = getStorage();
        if (!storage) return [];
        try {
            var parsed = JSON.parse(storage.getItem(MUTATION_QUEUE_KEY) || '[]');
            return Array.isArray(parsed) ? parsed : [];
        } catch (_) {
            return [];
        }
    }

    function writeQueue(items) {
        var storage = getStorage();
        if (!storage) return;
        storage.setItem(MUTATION_QUEUE_KEY, JSON.stringify(Array.isArray(items) ? items : []));
    }

    function getPendingMutationCount() {
        return readQueue().length;
    }

    function delay(ms) {
        return new Promise(function (resolve) {
            setTimeout(resolve, ms);
        });
    }

    function isOffline() {
        return typeof navigator !== 'undefined' && navigator.onLine === false;
    }

    function isNetworkError(error) {
        var message = String(error?.message || error || '').toLowerCase();
        return message.indexOf('failed to fetch') >= 0 ||
            message.indexOf('network') >= 0 ||
            message.indexOf('timeout') >= 0 ||
            message.indexOf('offline') >= 0 ||
            message.indexOf('fetch') >= 0;
    }

    async function executeWithRetry(factory, options) {
        var cfg = options || {};
        var retries = Number.isFinite(cfg.retries) ? cfg.retries : 3;
        var baseDelayMs = Number.isFinite(cfg.baseDelayMs) ? cfg.baseDelayMs : 450;
        var attempt = 0;
        var lastError = null;
        while (attempt <= retries) {
            try {
                return await factory();
            } catch (error) {
                lastError = error;
                if (attempt >= retries || !isNetworkError(error)) {
                    throw error;
                }
                await delay(baseDelayMs * Math.pow(2, attempt));
                attempt += 1;
            }
        }
        throw lastError || new Error('Falha desconhecida na operacao Supabase.');
    }

    function buildQueuedEnvelope(kind, table, payload, filters, options) {
        return {
            id: 'q-' + Date.now() + '-' + Math.random().toString(36).slice(2, 10),
            kind: kind,
            table: table,
            payload: payload || null,
            filters: Array.isArray(filters) ? filters : [],
            options: options || {},
            queuedAt: new Date().toISOString()
        };
    }

    function enqueueMutation(kind, table, payload, filters, options) {
        var queue = readQueue();
        var envelope = buildQueuedEnvelope(kind, table, payload, filters, options);
        queue.push(envelope);
        writeQueue(queue);
        return envelope;
    }

    async function executeEnvelope(envelope) {
        var client = createClient();
        var builder;
        if (envelope.kind === 'insert') {
            builder = client.from(envelope.table).insert(envelope.payload);
        } else if (envelope.kind === 'upsert') {
            builder = client.from(envelope.table).upsert(envelope.payload, envelope.options?.upsertOptions || {});
        } else if (envelope.kind === 'update') {
            builder = client.from(envelope.table).update(envelope.payload);
            (envelope.filters || []).forEach(function (filter) {
                if (!filter || !filter.column) return;
                var op = String(filter.operator || 'eq');
                if (typeof builder[op] === 'function') {
                    builder = builder[op](filter.column, filter.value);
                }
            });
        } else if (envelope.kind === 'remove') {
            builder = client.from(envelope.table).delete();
            (envelope.filters || []).forEach(function (filter) {
                if (!filter || !filter.column) return;
                var op = String(filter.operator || 'eq');
                if (typeof builder[op] === 'function') {
                    builder = builder[op](filter.column, filter.value);
                }
            });
        } else {
            throw new Error('Tipo de envelope nao suportado.');
        }

        if (envelope.options?.select && envelope.kind !== 'remove') {
            builder = builder.select(envelope.options.select);
        }

        var result = await builder;
        if (result.error) {
            throw result.error;
        }
        return result;
    }

    async function processPendingQueue() {
        if (queueProcessing) {
            return queueProcessing;
        }
        if (isOffline()) {
            return { processed: 0, remaining: getPendingMutationCount() };
        }

        queueProcessing = (async function () {
            var queue = readQueue();
            if (!queue.length) {
                return { processed: 0, remaining: 0 };
            }
            var processed = 0;
            var remaining = [];
            for (var index = 0; index < queue.length; index += 1) {
                var item = queue[index];
                try {
                    await executeWithRetry(function () {
                        return executeEnvelope(item);
                    }, {
                        retries: Number.isFinite(item.options?.retries) ? item.options.retries : 2,
                        baseDelayMs: Number.isFinite(item.options?.retryDelayMs) ? item.options.retryDelayMs : 600
                    });
                    processed += 1;
                } catch (error) {
                    remaining.push(item);
                    if (isNetworkError(error)) {
                        for (var next = index + 1; next < queue.length; next += 1) {
                            remaining.push(queue[next]);
                        }
                        break;
                    }
                }
            }
            writeQueue(remaining);
            return { processed: processed, remaining: remaining.length };
        })();

        try {
            return await queueProcessing;
        } finally {
            queueProcessing = null;
        }
    }

    async function query(table, queryBuilder) {
        var client = createClient();
        var base = client.from(table);
        var response = await executeWithRetry(function () {
            return queryBuilder(base);
        }, { retries: 2, baseDelayMs: 350 });
        var data = response?.data;
        var error = response?.error;
        if (error) {
            throw error;
        }
        return data;
    }

    async function getAccessToken() {
        try {
            var client = createClient();
            var result = await client.auth.getSession();
            return result?.data?.session?.access_token || global.CONFIG?.supabase?.anonKey || '';
        } catch (_) {
            return global.CONFIG?.supabase?.anonKey || '';
        }
    }

    async function fetchCurrentUserId() {
        var client = createClient();
        var session = await client.auth.getSession();
        var userId = session?.data?.session?.user?.id;
        if (!userId) {
            throw new Error('Usuario nao autenticado.');
        }
        return userId;
    }

    function normalizeGroupList(value) {
        if (Array.isArray(value)) {
            return value.map(function (item) {
                return String(item || '').trim().toLowerCase();
            }).filter(Boolean);
        }
        if (typeof value === 'string') {
            return value.split(',').map(function (item) {
                return String(item || '').trim().toLowerCase();
            }).filter(Boolean);
        }
        return [];
    }

    async function fetchCurrentProfile(force) {
        var userId = await fetchCurrentUserId();
        if (!force && currentProfileCache.userId === userId && currentProfileCache.profile) {
            return currentProfileCache.profile;
        }
        var rows = await list('profiles', {
            select: '*',
            filters: [{ column: 'id', value: userId }],
            limit: 1
        });
        var profile = rows && rows[0] ? rows[0] : {
            id: userId,
            role: 'operacional',
            groups: []
        };
        profile.groups = normalizeGroupList(profile.groups);
        currentProfileCache = { userId: userId, profile: profile };
        return profile;
    }

    function mergePreferencePayload(existing, scope, payload) {
        var base = existing && typeof existing === 'object' ? Object.assign({}, existing) : {};
        if (!scope) {
            return Object.assign(base, payload || {});
        }
        if (base.scope === scope) {
            delete base.scope;
        }
        base[scope] = Object.assign({}, base[scope] || {}, payload || {});
        return base;
    }

    function canReadSavedView(row, userId, profile) {
        if (!row) return false;
        if (String(row.owner_profile_id || '') === String(userId || '')) return true;
        var visibility = String(row.visibility_scope || 'private');
        if (visibility === 'private') return false;
        if (visibility === 'role') {
            return !!profile && String(row.shared_role || '').trim().toLowerCase() === String(profile.role || '').trim().toLowerCase();
        }
        if (visibility === 'group') {
            var rowGroups = normalizeGroupList(row.shared_groups);
            var profileGroups = normalizeGroupList(profile?.groups);
            return rowGroups.some(function (groupKey) {
                return profileGroups.indexOf(groupKey) >= 0;
            });
        }
        return false;
    }

    async function fetchAllRows(options) {
        var cfg = options || {};
        var table = String(cfg.table || '').trim();
        var select = String(cfg.select || '*').trim() || '*';
        var pageSize = Number.isFinite(cfg.pageSize) ? cfg.pageSize : 1000;
        var timeoutMs = Number.isFinite(cfg.timeoutMs) ? cfg.timeoutMs : 20000;
        if (!table) {
            throw new Error('Tabela nao informada.');
        }

        var client = createClient();
        try {
            var from = 0;
            var items = [];
            while (true) {
                var to = from + pageSize - 1;
                var response = await executeWithRetry(function () {
                    return client.from(table).select(select).range(from, to);
                }, { retries: 2, baseDelayMs: 400 });
                if (response.error) {
                    throw response.error;
                }
                var chunk = Array.isArray(response.data) ? response.data : [];
                if (!chunk.length) {
                    break;
                }
                items = items.concat(chunk);
                if (chunk.length < pageSize) {
                    break;
                }
                from += pageSize;
            }
            return items;
        } catch (clientError) {
            if (global.DunamisDataLayer && typeof global.DunamisDataLayer.fetchSupabaseTablePaged === 'function') {
                var token = await getAccessToken();
                var rows = await global.DunamisDataLayer.fetchSupabaseTablePaged({
                    baseUrl: global.CONFIG?.supabase?.url || '',
                    table: table,
                    anonKey: global.CONFIG?.supabase?.anonKey || '',
                    accessToken: token,
                    pageSize: pageSize,
                    timeoutMs: timeoutMs
                });
                return Array.isArray(rows) ? rows : [];
            }
            throw clientError;
        }
    }

    async function list(table, options) {
        var cfg = options || {};
        return query(table, function (base) {
            var builder = base.select(cfg.select || '*');
            (cfg.filters || []).forEach(function (filter) {
                if (!filter || !filter.column) return;
                var op = String(filter.operator || 'eq');
                if (typeof builder[op] === 'function') {
                    builder = builder[op](filter.column, filter.value);
                }
            });
            if (cfg.orderBy) {
                builder = builder.order(cfg.orderBy, { ascending: cfg.ascending !== false });
            }
            if (Number.isFinite(cfg.limit)) {
                builder = builder.limit(cfg.limit);
            }
            return builder;
        });
    }

    async function runMutation(kind, table, payload, filters, options) {
        var cfg = options || {};
        if (isOffline() && cfg.queueOnOffline !== false) {
            enqueueMutation(kind, table, payload, filters, cfg);
            return [{ queued: true, table: table, kind: kind }];
        }
        try {
            var result = await executeWithRetry(function () {
                return executeEnvelope(buildQueuedEnvelope(kind, table, payload, filters, cfg));
            }, {
                retries: Number.isFinite(cfg.retries) ? cfg.retries : 2,
                baseDelayMs: Number.isFinite(cfg.retryDelayMs) ? cfg.retryDelayMs : 500
            });
            if (kind === 'remove') {
                return true;
            }
            return result.data;
        } catch (error) {
            if (cfg.queueOnOffline !== false && isNetworkError(error)) {
                enqueueMutation(kind, table, payload, filters, cfg);
                return [{ queued: true, table: table, kind: kind }];
            }
            throw error;
        }
    }

    async function upsert(table, payload, options) {
        return runMutation('upsert', table, payload, null, options);
    }

    async function insert(table, payload, options) {
        return runMutation('insert', table, payload, null, options);
    }

    async function update(table, payload, filters, options) {
        return runMutation('update', table, payload, filters, options);
    }

    async function updateWithConflictCheck(table, payload, filters, options) {
        var cfg = options || {};
        var currentRows = await list(table, {
            select: '*',
            filters: filters || [],
            limit: 1
        });
        var current = currentRows && currentRows[0] ? currentRows[0] : null;
        if (cfg.expectedUpdatedAt && current?.updated_at && String(cfg.expectedUpdatedAt) !== String(current.updated_at)) {
            var conflictError = new Error('Registro alterado por outra sessao.');
            conflictError.code = 'DUNAMIS_CONFLICT';
            conflictError.current = current;
            throw conflictError;
        }
        var rows = await update(table, payload, filters, {
            select: cfg.select || '*',
            queueOnOffline: cfg.queueOnOffline,
            retries: cfg.retries,
            retryDelayMs: cfg.retryDelayMs
        });
        return {
            previous: current,
            data: Array.isArray(rows) ? rows[0] : rows
        };
    }

    async function remove(table, filters, options) {
        return runMutation('remove', table, null, filters, options);
    }

    function subscribeToTable(table, onEvent, options) {
        var cfg = options || {};
        var client = createClient();
        var channelName = cfg.channelName || ('dunamis-' + table + '-' + Date.now());
        var eventName = cfg.event || '*';
        var filter = cfg.filter;
        var channel = client.channel(channelName).on('postgres_changes', {
            event: eventName,
            schema: 'public',
            table: table,
            filter: filter
        }, function (payload) {
            if (typeof onEvent === 'function') {
                onEvent(payload);
            }
        }).subscribe();
        return function unsubscribe() {
            try {
                client.removeChannel(channel);
            } catch (_) {}
        };
    }

    async function logAudit(entry) {
        var payload = entry || {};
        return insert('audit_log', {
            entity_type: payload.entityType || 'system',
            entity_id: String(payload.entityId || ''),
            action: payload.action || 'update',
            group_key: payload.groupKey || null,
            unit: payload.unit || null,
            reason: payload.reason || null,
            previous_value: payload.previousValue || {},
            next_value: payload.nextValue || {},
            payload: payload.payload || {}
        }, { queueOnOffline: true });
    }

    async function createActivityFeed(entry) {
        var payload = entry || {};
        return insert('activity_feed', {
            entity_type: payload.entityType || 'system',
            entity_id: String(payload.entityId || ''),
            action: payload.action || 'update',
            group_key: payload.groupKey || null,
            unit: payload.unit || null,
            summary: payload.summary || '',
            payload: payload.payload || {}
        }, { select: '*', queueOnOffline: true });
    }

    async function addComment(entry) {
        var payload = entry || {};
        return insert('entity_comments', {
            entity_type: payload.entityType || 'system',
            entity_id: String(payload.entityId || ''),
            comment_text: payload.commentText || '',
            visibility: payload.visibility || 'internal'
        }, { select: '*', queueOnOffline: true });
    }

    async function addAttachment(entry) {
        var payload = entry || {};
        return insert('attachments', {
            entity_type: payload.entityType || 'system',
            entity_id: String(payload.entityId || ''),
            file_name: payload.fileName || 'anexo',
            mime_type: payload.mimeType || null,
            storage_path: payload.storagePath || null,
            metadata: payload.metadata || {}
        }, { select: '*', queueOnOffline: true });
    }

    async function getPreferences(scope) {
        var userId = await fetchCurrentUserId();
        var rows = await list('user_preferences', {
            select: '*',
            filters: [{ column: 'owner_profile_id', value: userId }],
            limit: 1
        });
        var payload = rows && rows[0] ? rows[0].payload || {} : {};
        if (!scope) {
            return payload;
        }
        var payloadScope = payload.scope === scope ? payload : payload[scope];
        return payloadScope || {};
    }

    async function savePreference(scope, payload) {
        var userId = await fetchCurrentUserId();
        var existing = await getPreferences();
        return upsert('user_preferences', {
            owner_profile_id: userId,
            payload: mergePreferencePayload(existing, scope || 'global', payload || {})
        }, { upsertOptions: { onConflict: 'owner_profile_id' }, select: '*', queueOnOffline: true });
    }

    async function listSavedViews(scope) {
        var userId = await fetchCurrentUserId();
        var profile = await fetchCurrentProfile();
        var client = createClient();
        var queryBuilder = client.from('saved_views').select('*').order('updated_at', { ascending: false }).limit(150);
        if (scope) {
            queryBuilder = queryBuilder.eq('scope', scope);
        }
        var result = await executeWithRetry(function () {
            return queryBuilder;
        }, { retries: 2, baseDelayMs: 350 });
        if (result.error) {
            throw result.error;
        }
        return (result.data || []).filter(function (row) {
            return canReadSavedView(row, userId, profile);
        });
    }

    async function saveSavedView(scope, title, filters, isDefault) {
        var userId = await fetchCurrentUserId();
        var profile = await fetchCurrentProfile();
        var options = typeof isDefault === 'object' && isDefault !== null ? isDefault : { isDefault: !!isDefault };
        var visibilityScope = String(options.visibilityScope || 'private');
        var sharedGroups = normalizeGroupList(options.sharedGroups || []);
        var sharedRole = String(options.sharedRole || profile.role || '').trim().toLowerCase() || null;
        if (visibilityScope === 'group' && !sharedGroups.length && profile.groups.length) {
            sharedGroups = profile.groups.slice();
        }
        if (options.isDefault) {
            try {
                await update('saved_views', {
                    is_default: false
                }, [
                    { column: 'owner_profile_id', value: userId },
                    { column: 'scope', value: scope }
                ], { queueOnOffline: true });
            } catch (_) {}
        }
        return insert('saved_views', {
            owner_profile_id: userId,
            scope: scope,
            title: title,
            is_default: !!options.isDefault,
            visibility_scope: visibilityScope,
            shared_role: visibilityScope === 'role' ? sharedRole : null,
            shared_groups: visibilityScope === 'group' ? sharedGroups : [],
            filters: filters || {}
        }, { select: '*', queueOnOffline: true });
    }

    async function createWorkflowRecord(table, payload) {
        return insert(table, payload, { select: '*', queueOnOffline: true });
    }

    async function updateWorkflowRecord(table, id, payload) {
        return update(table, payload, [{ column: 'id', value: id }], { select: '*', queueOnOffline: true });
    }

    async function createChecklistSubmission(payload) {
        return insert('checklist_submissions', payload, { select: '*', queueOnOffline: true });
    }

    async function createChecklistIssue(payload) {
        return insert('checklist_issues', payload, { select: '*', queueOnOffline: true });
    }

    async function healthCheck() {
        var client = createClient();
        var result = { ok: false, online: !isOffline(), queuedMutations: getPendingMutationCount(), authenticated: false };
        try {
            var session = await client.auth.getSession();
            result.authenticated = !!session?.data?.session;
            result.ok = true;
            return result;
        } catch (error) {
            result.error = String(error?.message || error || 'Falha no health check');
            return result;
        }
    }

    function bindLifecycle() {
        if (bindingsReady) return;
        bindingsReady = true;
        if (typeof window !== 'undefined') {
            window.addEventListener('online', function () {
                processPendingQueue().catch(function () {});
            });
            setTimeout(function () {
                processPendingQueue().catch(function () {});
            }, 300);
        }
    }

    bindLifecycle();

    global.DunamisSupabaseService = {
        createClient: createClient,
        query: query,
        fetchAllRows: fetchAllRows,
        list: list,
        insert: insert,
        update: update,
        updateWithConflictCheck: updateWithConflictCheck,
        upsert: upsert,
        remove: remove,
        subscribeToTable: subscribeToTable,
        processPendingQueue: processPendingQueue,
        getPendingMutationCount: getPendingMutationCount,
        healthCheck: healthCheck,
        logAudit: logAudit,
        createActivityFeed: createActivityFeed,
        addComment: addComment,
        addAttachment: addAttachment,
        getPreferences: getPreferences,
        savePreference: savePreference,
        listSavedViews: listSavedViews,
        saveSavedView: saveSavedView,
        createWorkflowRecord: createWorkflowRecord,
        updateWorkflowRecord: updateWorkflowRecord,
        createChecklistSubmission: createChecklistSubmission,
        createChecklistIssue: createChecklistIssue
    };
})(typeof window !== 'undefined' ? window : globalThis);
